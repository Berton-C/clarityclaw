# .env.example -- MeTTaClaw / ClarityClaw environment configuration
# SETUP: Copy this file to .env and fill in your values.
# docker-compose automatically loads .env from the project root.
# NEVER commit .env to git.

# ================================================================
# REQUIRED: OpenAI API Key
# One key handles everything:
#   useGPT() -> gpt-5.4 (confirmed in your account)
#   useGPTEmbedding() -> text-embedding-3-large
# ================================================================
OPENAI_API_KEY=sk-...

# ================================================================
# REQUIRED: Mattermost Bot Configuration
# Setup steps (do this BEFORE running docker compose up mettaclaw):
#
# Step 1: Start Mattermost first:
#   docker compose up postgres mattermost -d
#
# Step 2: Wait ~90 seconds, then visit http://localhost:8065
#
# Step 3: Create admin account (first time only)
#
# Step 4: Create a Bot Account:
#   System Console -> Integrations -> Bot Accounts -> Add Bot Account
#   Give it a username (e.g. "mettaclaw-bot")
#   Copy the generated token -> set MM_BOT_TOKEN below
#
# Step 5: Create a channel for the bot:
#   In Mattermost, create a channel (e.g. "mettaclaw")
#   Add the bot to the channel
#   Get channel ID: click channel name -> View Info
#   OR use API: curl http://localhost:8065/api/v4/channels/search
#   Set MM_CHANNEL_ID below
#
# Step 6: Then start the agent:
#   docker compose up mettaclaw -d
# ================================================================
MM_BOT_TOKEN=your_bot_token_here
MM_CHANNEL_ID=your_channel_id_here

# ================================================================
# OPTIONAL: Override defaults
# ================================================================

# Communication channel: mattermost (default) or irc
COMMCHANNEL=mattermost

# Postgres password (used internally -- change for production)
POSTGRES_PASSWORD=mmuser_password
